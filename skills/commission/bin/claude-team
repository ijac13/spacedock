#!/usr/bin/env python3
# ABOUTME: Team utility for Claude Code agent coordination.
# ABOUTME: Subcommands: context-budget, build (structured dispatch assembly).

import argparse
import glob
import importlib.machinery
import importlib.util
import json
import os
import re
import sys
from pathlib import Path

# --- Shared functions imported from sibling `status` script ---
# Borrowed surface: parse_frontmatter, parse_stages_block,
#     load_active_entity_fields, find_git_root
# These functions are tested via the sibling-import path in
# tests/test_claude_team.py::test_status_sibling_import_*
_here = Path(__file__).resolve().parent
_status_path = str(_here / "status")
_loader = importlib.machinery.SourceFileLoader("_status_lib", _status_path)
_spec = importlib.util.spec_from_file_location("_status_lib", _status_path, loader=_loader)
_status = importlib.util.module_from_spec(_spec)
_spec.loader.exec_module(_status)

parse_frontmatter = _status.parse_frontmatter
parse_stages_block = _status.parse_stages_block
parse_stages_with_defaults = _status.parse_stages_with_defaults
parse_mod_metadata = _status.parse_mod_metadata
load_active_entity_fields = _status.load_active_entity_fields
find_git_root = _status.find_git_root


SCHEMA_VERSION = 1
BUILD_REQUIRED_FIELDS = ('schema_version', 'entity_path', 'workflow_dir', 'stage', 'checklist')
NAME_PATTERN = re.compile(r'^[a-z0-9][a-z0-9-]*[a-z0-9]$')
NAME_MAX_LEN = 200
MODEL_ENUM = ('sonnet', 'opus', 'haiku')
MODEL_ENUM_LIST = 'must be one of: sonnet, opus, haiku'


def extract_stage_subsection(readme_path, stage_name):
    r"""Extract the full ### {stage_name} subsection from a workflow README.

    Accepts both backtick-quoted (`### \`work\``) and bare (`### work`) headings
    so fixtures and hand-authored workflows both parse cleanly.
    """
    with open(readme_path, 'r') as f:
        text = f.read()
    lines = text.splitlines()
    start = None
    accepted_headings = (f'### `{stage_name}`', f'### {stage_name}')
    for i, line in enumerate(lines):
        if line.strip() in accepted_headings:
            start = i
            break
    if start is None:
        return None
    end = len(lines)
    for i in range(start + 1, len(lines)):
        stripped = lines[i].strip()
        if stripped.startswith('### ') or stripped.startswith('## '):
            end = i
            break
    while end > start and not lines[end - 1].strip():
        end -= 1
    return '\n'.join(lines[start:end])


def _build_error(msg, code=1):
    """Print error to stderr and return exit code."""
    print(f'error: {msg}', file=sys.stderr)
    return code


def cmd_build(args):
    """Assemble a structured dispatch JSON from entity, workflow, and FO-supplied fragments."""
    workflow_dir = args.workflow_dir

    # Read stdin
    try:
        raw = sys.stdin.read()
    except Exception as e:
        return _build_error(f'failed to read stdin: {e}')

    try:
        inp = json.loads(raw)
    except json.JSONDecodeError as e:
        return _build_error(f'invalid JSON on stdin: {e}')

    if not isinstance(inp, dict):
        return _build_error('stdin must be a JSON object')

    # Rule 1: Required fields present
    for field in BUILD_REQUIRED_FIELDS:
        if field not in inp or inp[field] is None:
            return _build_error(f"missing required field '{field}'")

    # Rule 2: Schema version supported
    sv = inp['schema_version']
    if sv != SCHEMA_VERSION:
        return _build_error(f'unsupported input schema_version {sv}, expected {SCHEMA_VERSION}', code=2)

    entity_path = inp['entity_path']
    stage = inp['stage']
    checklist = inp['checklist']
    team_name = inp.get('team_name')
    feedback_context = inp.get('feedback_context')
    scope_notes = inp.get('scope_notes')
    bare_mode = inp.get('bare_mode', False)
    is_feedback_reflow = inp.get('is_feedback_reflow', False)

    # Rule 9: Checklist non-empty
    if not isinstance(checklist, list) or len(checklist) == 0:
        return _build_error('checklist must not be empty')

    # Rule 10: Entity file readable
    if not os.path.isfile(entity_path):
        return _build_error(f"entity file not readable at '{entity_path}'")

    # Rule 11: Workflow README readable
    readme_path = os.path.join(workflow_dir, 'README.md')
    if not os.path.isfile(readme_path):
        return _build_error(f"workflow README not found at '{readme_path}'")

    # Parse workflow stages + defaults
    stages, stage_defaults = parse_stages_with_defaults(readme_path)
    if stages is None:
        return _build_error(f"no stages block found in {readme_path}")

    stage_by_name = {s['name']: s for s in stages}

    # Rule 3: Stage exists in workflow
    if stage not in stage_by_name:
        return _build_error(f"stage '{stage}' not found in {readme_path}")

    stage_meta = stage_by_name[stage]

    # Resolve effective_model with precedence: stage > defaults > null.
    # Validate any declared value against the Agent-schema enum loudly.
    stage_model_raw = stage_meta.get('model')
    defaults_model_raw = stage_defaults.get('model') if stage_defaults else None

    stage_idx = next(
        (i for i, s in enumerate(stages) if s['name'] == stage), 0
    )
    if stage_model_raw is not None and stage_model_raw not in MODEL_ENUM:
        return _build_error(
            f"invalid model for stages.states[{stage_idx}].model: "
            f"'{stage_model_raw}' — {MODEL_ENUM_LIST}"
        )
    if defaults_model_raw is not None and defaults_model_raw not in MODEL_ENUM:
        return _build_error(
            f"invalid model for stages.defaults.model: "
            f"'{defaults_model_raw}' — {MODEL_ENUM_LIST}"
        )

    if stage_model_raw is not None:
        effective_model = stage_model_raw
        model_source = 'stage'
    elif defaults_model_raw is not None:
        effective_model = defaults_model_raw
        model_source = 'defaults'
    else:
        effective_model = None
        model_source = 'null'

    if effective_model is not None:
        print(
            f'[build] effective_model={effective_model} (from {model_source}) '
            f'\u2192 Agent model={effective_model}',
            file=sys.stderr,
        )

    # Rule 4: Worktree stage has worktree path
    entity_fields = parse_frontmatter(entity_path)
    entity_title = entity_fields.get('title', '')
    entity_worktree = entity_fields.get('worktree', '').strip()

    if stage_meta.get('worktree', False):
        if not entity_worktree:
            return _build_error(f"worktree stage '{stage}' but entity has no worktree path")
        git_root = find_git_root(workflow_dir)
        worktree_path = os.path.join(git_root, entity_worktree)
        if not os.path.isdir(worktree_path):
            return _build_error(f"worktree path '{worktree_path}' does not exist")
    else:
        worktree_path = None

    # Rule 5: Feedback context required for feedback reflow
    if is_feedback_reflow and not feedback_context:
        return _build_error(f"dispatching to feedback target stage '{stage}' but feedback_context is missing")

    # Rule 8: Team name non-empty in team mode
    if not bare_mode and not team_name:
        return _build_error('team mode requires team_name')

    # Rule 6: Derive subagent_type from stage agent field
    subagent_type = stage_meta.get('agent', 'spacedock:ensign')

    # Derive worker_key and name
    worker_key = subagent_type.replace(':', '-')
    slug = os.path.splitext(os.path.basename(entity_path))[0]
    derived_name = f'{worker_key}-{slug}-{stage}'

    # Rule 7: Name length and safety
    if len(derived_name) > NAME_MAX_LEN:
        return _build_error(f"derived name '{derived_name}' exceeds {NAME_MAX_LEN} characters")
    if not NAME_PATTERN.match(derived_name):
        return _build_error(f"derived name '{derived_name}' contains invalid characters")

    # Extract stage subsection from README
    stage_subsection = extract_stage_subsection(readme_path, stage)
    if stage_subsection is None:
        return _build_error(f"stage '{stage}' heading not found in {readme_path}")

    # --- Prompt Assembly (9 components) ---
    prompt_parts = []

    # 1. Header
    prompt_parts.append(f'You are working on: {entity_title}\n\nStage: {stage}\n')

    # 2. Stage definition
    prompt_parts.append(f'### Stage definition:\n\n{stage_subsection}\n')

    # 3. Worktree instructions (conditional)
    if worktree_path:
        branch = f'{worker_key}/{slug}'
        prompt_parts.append(
            f'Your working directory is {worktree_path}\n'
            f'All file reads and writes MUST use paths under {worktree_path}.\n'
            f'Your git branch is {branch}. All commits MUST be on this branch. '
            f'Do NOT switch branches or commit to main.\n'
        )

    # 4. Entity read instruction
    if worktree_path:
        entity_rel = os.path.relpath(entity_path, git_root)
        worktree_entity_path = os.path.join(worktree_path, entity_rel)
        prompt_parts.append(
            f'Read the entity file at {worktree_entity_path} for the full spec. '
            f'It contains:\n'
        )
    else:
        prompt_parts.append(
            f'Read the entity file at {entity_path} for the current spec.\n'
        )

    # 5. Do-not-modify block (always)
    prompt_parts.append(
        'Do NOT modify YAML frontmatter in entity files.\n'
        'Do NOT modify files under agents/ or references/ — these are plugin scaffolding.\n'
    )

    # 6. Feedback context (conditional)
    if feedback_context:
        prompt_parts.append(f'### Feedback from prior review\n\n{feedback_context}\n')

    # 7. Scope notes (conditional)
    if scope_notes:
        prompt_parts.append(f'{scope_notes}\n')

    # 8. Completion checklist
    checklist_text = '\n'.join(checklist)
    prompt_parts.append(
        '### Completion checklist\n\n'
        'Write a ## Stage Report section into the entity file when done.\n'
        'Mark each: DONE, SKIPPED (with rationale), or FAILED (with details).\n\n'
        f'{checklist_text}\n\n'
        '### Summary\n'
        '{brief description of what was accomplished}\n\n'
        'Every checklist item must appear in your report. Do not omit items.'
    )

    # 9. Standing teammates available (conditional: team mode, alive members found)
    standing_teammates = enumerate_declared_standing_teammates(workflow_dir, team_name)
    if standing_teammates:
        lines = [
            '### Standing teammates available in your team',
            '',
            'These standing teammates are available in your team; you MAY route to them via '
            'SendMessage. Best-effort, non-blocking, 2-minute timeout; proceed with '
            'un-polished/un-reviewed content if no reply.',
            '',
        ]
        for name, description, mod_path in standing_teammates:
            desc = description or 'standing teammate'
            usage_body = _parse_routing_usage_body(mod_path) if mod_path else None
            if usage_body:
                lines.append(f'- **{name}** ({desc})')
                for body_line in usage_body.split('\n'):
                    if body_line:
                        lines.append(f'  {body_line}')
                    else:
                        lines.append('')
            else:
                lines.append(
                    f'- **{name}** ({desc}): SendMessage with the relevant input '
                    f'shape; reply format per the mod.'
                )
        lines.append('')
        lines.append(
            'Full routing contract: see '
            '`skills/first-officer/references/first-officer-shared-core.md` '
            '`## Standing Teammates`.'
        )
        prompt_parts.append('\n'.join(lines))

    # 10. Completion signal (conditional, team mode only)
    if not bare_mode and team_name:
        entity_file_ref = worktree_entity_path if worktree_path else entity_path
        prompt_parts.append(
            '\n\n### Completion Signal\n\n'
            'This is a team-mode dispatch. When you finish (after all commits and '
            'stage report writes are done), your last action MUST be:\n\n'
            f'    SendMessage(to="team-lead", message="Done: {entity_title} completed '
            f'{stage}. Report written to {entity_file_ref}.")\n\n'
            'Plain text only. No JSON. Until you send this message, the first officer '
            'keeps waiting for that explicit completion message. Idle notifications are '
            'normal between-turn state while it waits.\n\n'
            '**If you are the first officer forwarding this prompt to Agent():** copy '
            'the entire block above into `Agent(prompt=...)` character-for-character. '
            'Do NOT paraphrase `SendMessage(to="team-lead", ...)` as "SendMessage with '
            'to=\'team-lead\'" or any other English rewrite — the parenthesis-equals '
            'syntax is the literal call the ensign must emit, not a description of one.'
        )

    prompt = '\n'.join(prompt_parts)

    # Build output
    output = {
        'schema_version': SCHEMA_VERSION,
        'subagent_type': subagent_type,
        'description': f'{entity_title}: {stage}',
        'prompt': prompt,
        'model': effective_model,
    }

    if not bare_mode:
        output['name'] = derived_name
        if team_name:
            output['team_name'] = team_name

    print(json.dumps(output, indent=2))
    return 0


DEFAULT_CONTEXT_LIMIT = 200000
EXTENDED_CONTEXT_LIMIT = 1000000
THRESHOLD_PCT = 60


def find_subagent_jsonl(name: str) -> str | None:
    """Find the most recently modified subagent jsonl matching the given name.

    Looks up the team config containing a member named `name`, reads its
    `leadSessionId`, and globs only that session's subagents directory:
    ~/.claude/projects/*/{leadSessionId}/subagents/agent-*.meta.json. On a
    populated machine this narrows the haystack from thousands of files
    (every project's subagents) to dozens (one session's subagents).

    Falls back to the broad scan if no team config is found, no
    leadSessionId is set, or the narrowed scan returns nothing — the broad
    scan stays correct, just slow. A warning is emitted to stderr in the
    fallback case.

    Scans agent-*.meta.json for agentType matching name.
    Returns the sibling .jsonl path, or None.
    """
    home = os.path.expanduser("~")
    broad_patterns = [
        os.path.join(home, ".claude", "projects", "*", "subagents", "agent-*.meta.json"),
        os.path.join(home, ".claude", "projects", "*", "*", "subagents", "agent-*.meta.json"),
    ]

    narrowed = _narrowed_subagent_patterns(home, name)
    if narrowed is not None:
        matches = _scan_subagent_meta(narrowed, name)
        if not matches:
            print(
                f"warning: narrowed subagent scan for {name!r} found nothing; "
                f"falling back to broad ~/.claude/projects scan",
                file=sys.stderr,
            )
            matches = _scan_subagent_meta(broad_patterns, name)
    else:
        matches = _scan_subagent_meta(broad_patterns, name)

    if not matches:
        return None

    matches.sort(key=lambda x: x[0], reverse=True)
    return matches[0][1]


def _narrowed_subagent_patterns(home: str, name: str) -> list[str] | None:
    """Return narrowed glob patterns for a subagent jsonl scoped to one team session.

    Returns None when no team config containing `name` declares a leadSessionId.
    """
    teams_pattern = os.path.join(home, ".claude", "teams", "*", "config.json")
    for config_path in glob.glob(teams_pattern):
        try:
            with open(config_path, "r") as f:
                config = json.load(f)
        except (json.JSONDecodeError, OSError):
            continue
        member_names = {m.get("name") for m in config.get("members", []) if isinstance(m, dict)}
        if name not in member_names:
            continue
        lead_session_id = config.get("leadSessionId")
        if not lead_session_id:
            continue
        return [
            os.path.join(
                home, ".claude", "projects", "*", lead_session_id, "subagents",
                "agent-*.meta.json",
            ),
        ]
    return None


def _scan_subagent_meta(patterns: list[str], name: str) -> list[tuple[float, str]]:
    matches: list[tuple[float, str]] = []
    for pattern in patterns:
        for meta_path in glob.glob(pattern):
            try:
                with open(meta_path, "r") as f:
                    meta = json.load(f)
                if meta.get("agentType") == name:
                    mtime = os.path.getmtime(meta_path)
                    jsonl_path = meta_path.replace(".meta.json", ".jsonl")
                    if os.path.isfile(jsonl_path):
                        matches.append((mtime, jsonl_path))
            except (json.JSONDecodeError, OSError):
                continue
    return matches


def extract_resident_tokens(jsonl_path: str) -> int | None:
    """Extract resident tokens by scanning backward for the first non-zero usage.

    An ensign that dies mid-turn (context overflow) leaves a trailing assistant
    entry with all-zero usage fields. Scanning backward from end-of-file for the
    first assistant entry with a non-zero usage sum yields the true peak resident
    tokens for both live ensigns (last turn) and dead ensigns (last real turn).

    Returns input_tokens + cache_creation_input_tokens + cache_read_input_tokens,
    or None if no assistant entry with non-zero usage is found.
    """
    with open(jsonl_path, "r") as f:
        lines = f.readlines()

    for line in reversed(lines):
        line = line.strip()
        if not line:
            continue
        try:
            entry = json.loads(line)
        except json.JSONDecodeError:
            continue
        if entry.get("type") != "assistant":
            continue
        msg = entry.get("message", {})
        if not isinstance(msg, dict):
            continue
        usage = msg.get("usage")
        if not isinstance(usage, dict):
            continue
        resident = (
            usage.get("input_tokens", 0)
            + usage.get("cache_creation_input_tokens", 0)
            + usage.get("cache_read_input_tokens", 0)
        )
        if resident > 0:
            return resident

    return None


def extract_runtime_models(jsonl_path: str) -> set[str]:
    """Extract distinct model strings from assistant entries in the jsonl."""
    models = set()
    with open(jsonl_path, "r") as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            try:
                entry = json.loads(line)
            except json.JSONDecodeError:
                continue
            if entry.get("type") != "assistant":
                continue
            msg = entry.get("message", {})
            if not isinstance(msg, dict):
                continue
            model = msg.get("model")
            if model:
                models.add(model)
    return models


def enumerate_declared_standing_teammates(workflow_dir: str, team_name) -> list[tuple[str, str, str]]:
    """Return [(name, description, mod_path)] for declared standing teammates.

    Scans `{workflow_dir}/_mods/*.md` for mod files with `standing: true`
    in frontmatter (parsed via parse_mod_metadata). Returns all declared
    standing teammates from mod metadata, regardless of whether they are
    currently alive in the team. This supports lazy-spawn: teammates may
    not yet be spawned at dispatch time.

    Degenerate cases return an empty list:
    - `team_name` is None or empty (bare mode)
    - no `_mods/` directory exists under `workflow_dir`
    - no `standing: true` mods found

    The name comes from the mod's `## Hook: startup` section
    (authoritative — this is the same name `claude-team spawn-standing`
    hands to Agent() at spawn time). The description comes from the mod
    frontmatter's `description` field. The mod_path lets callers re-read
    the same mod for per-teammate payload extras (e.g., `## Routing
    Usage`) without re-globbing.
    """
    if not team_name:
        return []

    mods_dir = os.path.join(workflow_dir, "_mods")
    if not os.path.isdir(mods_dir):
        return []

    declared = []
    for mod_path in sorted(glob.glob(os.path.join(mods_dir, "*.md"))):
        try:
            meta = parse_mod_metadata(mod_path)
        except (ValueError, OSError):
            continue
        if not meta["standing"]:
            continue
        hook_config = _parse_hook_startup_spawn_config(mod_path)
        declared_name = hook_config.get("name") or meta["name"]
        if not declared_name:
            continue
        description = meta["frontmatter"].get("description", "")
        declared.append((declared_name, description, mod_path))
    return declared


def member_exists(team: str, name: str) -> bool:
    """Return True iff member {name} is in team {team}'s config.json members list.

    Sibling of lookup_model, not an extension. lookup_model globs ALL team
    configs to answer "what model does agent X run as anywhere" — appropriate
    for reuse-model comparison. The standing-spawn check is team-scoped: two
    parallel teams in the same captain session may each spawn their own
    comm-officer, so this helper opens exactly one config file.
    """
    home = os.path.expanduser("~")
    config_path = os.path.join(home, ".claude", "teams", team, "config.json")
    if not os.path.isfile(config_path):
        return False
    try:
        with open(config_path, "r") as f:
            config = json.load(f)
    except (json.JSONDecodeError, OSError):
        return False
    for member in config.get("members", []):
        if member.get("name") == name:
            return True
    return False


def _parse_routing_usage_body(mod_path: str) -> str | None:
    """Extract the body of a mod's `## Routing Usage` section, or None.

    Returns the text between the `## Routing Usage` heading and the next
    `## ` heading (or EOF), with surrounding blank lines stripped. Returns
    None when the section is missing, empty, or contains only whitespace —
    callers render the fallback one-liner in those cases.
    """
    try:
        with open(mod_path, "r") as f:
            content = f.read()
    except OSError:
        return None
    lines = content.split("\n")

    start = None
    for i, line in enumerate(lines):
        if line.strip() == "## Routing Usage":
            start = i
            break
    if start is None:
        return None

    end = len(lines)
    for i in range(start + 1, len(lines)):
        if lines[i].startswith("## "):
            end = i
            break

    body_lines = lines[start + 1:end]
    while body_lines and not body_lines[0].strip():
        body_lines.pop(0)
    while body_lines and not body_lines[-1].strip():
        body_lines.pop()
    if not body_lines:
        return None
    return "\n".join(body_lines)


def _parse_hook_startup_spawn_config(mod_path: str) -> dict:
    """Extract subagent_type / name / model from a mod's `## Hook: startup` section.

    The `## Hook: startup` section in a standing-teammate mod declares
    spawn config as markdown bullets of the form `- key: value`. The pilot
    mod (docs/plans/_mods/comm-officer.md) uses backtick-wrapped inline
    code for each field (e.g. `` - `subagent_type: general-purpose` ``) so
    we strip backticks from values when detected.

    Returns a dict with keys `subagent_type`, `name`, `model`. Missing keys
    are absent from the dict (the caller validates required fields).
    """
    with open(mod_path, "r") as f:
        content = f.read()
    lines = content.split("\n")

    hook_start = None
    for i, line in enumerate(lines):
        if line.strip() == "## Hook: startup":
            hook_start = i
            break
    if hook_start is None:
        return {}

    hook_end = len(lines)
    for i in range(hook_start + 1, len(lines)):
        if lines[i].startswith("## "):
            hook_end = i
            break

    config = {}
    for line in lines[hook_start + 1:hook_end]:
        stripped = line.strip()
        if not stripped.startswith("- "):
            continue
        item = stripped[2:].strip()
        # Strip surrounding backticks if the whole bullet is wrapped as inline code
        if item.startswith("`") and item.endswith("`") and len(item) >= 2:
            item = item[1:-1]
        if ":" not in item:
            continue
        key, _, value = item.partition(":")
        key = key.strip()
        value = value.strip()
        # Strip trailing inline comments introduced by a backtick pair
        if value.startswith("`") and value.endswith("`") and len(value) >= 2:
            value = value[1:-1]
        if key in ("subagent_type", "name", "model"):
            config[key] = value

    return config


def cmd_spawn_standing(args: argparse.Namespace) -> int:
    """Emit an Agent() spec JSON for a standing-teammate mod, or report already-alive.

    Reads a mod file at --mod, validates `standing: true` in frontmatter,
    extracts spawn config from `## Hook: startup`, and checks the target
    team's config.json for an existing member with the declared name.

    - If the member already exists in the team config, emit
      `{"status": "already-alive", "name": "..."}` on stdout (exit 0).
    - Otherwise emit an Agent() call spec JSON shaped like `claude-team build`
      output: subagent_type, name, team_name, model, prompt.

    Fails loudly (non-zero exit, stderr) on: missing mod file, missing
    `standing: true`, missing `## Agent Prompt` section, model value outside
    the sonnet/opus/haiku enum, or a convention-violating trailing heading
    after `## Agent Prompt` (caught by parse_mod_metadata).
    """
    mod_path = args.mod
    team_name = args.team

    if not os.path.isfile(mod_path):
        print(f"error: mod file not found: {mod_path}", file=sys.stderr)
        return 1

    try:
        meta = parse_mod_metadata(mod_path)
    except ValueError as e:
        print(f"error: {e}", file=sys.stderr)
        return 1

    if not meta["standing"]:
        print(
            f"error: mod {mod_path} is missing 'standing: true' in frontmatter — "
            f"not a standing-teammate mod",
            file=sys.stderr,
        )
        return 1

    if meta["agent_prompt"] is None:
        print(
            f"error: mod {mod_path} has no '## Agent Prompt' section — "
            f"required for standing-teammate spawn",
            file=sys.stderr,
        )
        return 1

    hook_config = _parse_hook_startup_spawn_config(mod_path)

    subagent_type = hook_config.get("subagent_type") or meta["frontmatter"].get("subagent_type", "")
    declared_name = hook_config.get("name") or meta["name"]
    model = hook_config.get("model", "")

    if not subagent_type:
        print(
            f"error: mod {mod_path} has no 'subagent_type' in '## Hook: startup' "
            f"or frontmatter",
            file=sys.stderr,
        )
        return 1
    if not declared_name:
        print(
            f"error: mod {mod_path} has no 'name' in '## Hook: startup' or frontmatter",
            file=sys.stderr,
        )
        return 1
    if not model:
        print(
            f"error: mod {mod_path} has no 'model' in '## Hook: startup' — "
            f"{MODEL_ENUM_LIST}",
            file=sys.stderr,
        )
        return 1
    if model not in MODEL_ENUM:
        print(
            f"error: invalid model '{model}' in '## Hook: startup' of {mod_path} — "
            f"{MODEL_ENUM_LIST}",
            file=sys.stderr,
        )
        return 1

    if member_exists(team_name, declared_name):
        print(json.dumps({"status": "already-alive", "name": declared_name}))
        return 0

    spec = {
        "subagent_type": subagent_type,
        "name": declared_name,
        "team_name": team_name,
        "model": model,
        "prompt": meta["agent_prompt"],
    }
    print(json.dumps(spec, indent=2))
    return 0


def cmd_list_standing(args: argparse.Namespace) -> int:
    """Emit absolute paths of `standing: true` mods under {workflow_dir}/_mods/*.md.

    Used at FO boot (before team members exist) to enumerate which standing
    mods to hand to `spawn-standing`. This is NOT the same predicate as
    `enumerate_declared_standing_teammates`, which returns tuples of
    (name, description, mod_path) for dispatch-prompt assembly. Keep the
    two call paths distinct.

    Output format: one absolute mod path per line, sorted alphabetically
    by filename. Paths are whitespace-free by `_mods/*.md` naming
    convention (kebab-case) — if that ever changes, switch to `-0` NUL
    delimiting or `--json`.

    Exit 0 on success, including zero matches (empty stdout). Exit
    non-zero only when the workflow directory cannot be resolved.
    """
    workflow_dir = args.workflow_dir
    if not os.path.isdir(workflow_dir):
        print(
            f"error: workflow directory not found: {workflow_dir}",
            file=sys.stderr,
        )
        return 1

    mods_dir = os.path.join(workflow_dir, "_mods")
    if not os.path.isdir(mods_dir):
        return 0

    standing_paths = []
    for mod_path in sorted(glob.glob(os.path.join(mods_dir, "*.md"))):
        try:
            meta = parse_mod_metadata(mod_path)
        except (ValueError, OSError) as e:
            print(f"error: unreadable mod {mod_path}: {e}", file=sys.stderr)
            return 1
        if meta["standing"]:
            standing_paths.append(os.path.abspath(mod_path))

    for path in standing_paths:
        print(path)
    return 0


def lookup_model(name: str) -> str | None:
    """Find the model for a team member by name.

    Scans ~/.claude/teams/*/config.json for a member whose name matches.
    Returns the model string, or None.
    """
    home = os.path.expanduser("~")
    pattern = os.path.join(home, ".claude", "teams", "*", "config.json")

    for config_path in glob.glob(pattern):
        try:
            with open(config_path, "r") as f:
                config = json.load(f)
            for member in config.get("members", []):
                if member.get("name") == name:
                    return member.get("model")
        except (json.JSONDecodeError, OSError):
            continue

    return None


def context_limit_for_model(model: str) -> int:
    """Infer the context window size from the model name suffix.

    Claude Code encodes extended-context variants with a bracket suffix like
    `[1m]` (e.g. `claude-opus-4-6[1m]`). Any model name containing `[1m]` is
    the 1M-context variant. Everything else defaults to 200k, which is the
    standard Claude context window and safe fallback for unknown models.
    """
    if "[1m]" in model:
        return EXTENDED_CONTEXT_LIMIT
    return DEFAULT_CONTEXT_LIMIT


def cmd_context_budget(args: argparse.Namespace) -> int:
    name = args.name

    jsonl_path = find_subagent_jsonl(name)
    if jsonl_path is None:
        print(f"Error: no subagent jsonl found for '{name}'", file=sys.stderr)
        return 1

    resident_tokens = extract_resident_tokens(jsonl_path)
    if resident_tokens is None:
        print(f"Error: no assistant entries with usage in {jsonl_path}", file=sys.stderr)
        return 1

    config_model = lookup_model(name)
    if config_model is None:
        print(f"Error: no team config found for member '{name}'", file=sys.stderr)
        return 1

    runtime_models = extract_runtime_models(jsonl_path)
    warnings = {}

    if len(runtime_models) > 1:
        model = min(runtime_models, key=context_limit_for_model)
        warnings["mixed_models_warning"] = (
            f"multiple models seen in jsonl: {sorted(runtime_models)} — using smallest context window"
        )
    elif len(runtime_models) == 1:
        model = next(iter(runtime_models))
    else:
        model = config_model
        warnings["config_fallback_warning"] = (
            "no model field in jsonl assistant entries — using config-declared model (provisional)"
        )

    context_limit = context_limit_for_model(model)
    config_limit = context_limit_for_model(config_model)

    if runtime_models and config_limit != context_limit:
        warnings["config_drift_warning"] = (
            f"team config requested {config_model} but runtime is {model}"
        )

    usage_pct = round(resident_tokens / context_limit * 100, 1)
    reuse_ok = usage_pct <= THRESHOLD_PCT

    result = {
        "name": name,
        "resident_tokens": resident_tokens,
        "model": model,
        "context_limit": context_limit,
        "usage_pct": usage_pct,
        "threshold_pct": THRESHOLD_PCT,
        "reuse_ok": reuse_ok,
    }
    if runtime_models and config_limit != context_limit:
        result["config_declared_model"] = config_model
    result.update(warnings)

    print(json.dumps(result, indent=2))
    return 0


def main():
    parser = argparse.ArgumentParser(description="Claude Code team utilities")
    subparsers = parser.add_subparsers(dest="command")

    budget_parser = subparsers.add_parser("context-budget", help="Check agent context budget")
    budget_parser.add_argument("--name", required=True, help="Agent name to look up")

    build_parser = subparsers.add_parser("build", help="Assemble structured dispatch JSON")
    build_parser.add_argument("--workflow-dir", required=True, help="Absolute path to workflow directory")

    spawn_parser = subparsers.add_parser(
        "spawn-standing",
        help="Emit Agent() spec JSON for a standing-teammate mod, or report already-alive",
    )
    spawn_parser.add_argument("--mod", required=True, help="Path to the standing-teammate mod file")
    spawn_parser.add_argument("--team", required=True, help="Target team name")

    list_standing_parser = subparsers.add_parser(
        "list-standing",
        help="List absolute paths of standing-teammate mod files (one per line)",
    )
    list_standing_parser.add_argument(
        "--workflow-dir", required=True, help="Absolute path to workflow directory"
    )

    args = parser.parse_args()

    if args.command is None:
        parser.print_help(sys.stderr)
        sys.exit(1)

    if args.command == "context-budget":
        sys.exit(cmd_context_budget(args))
    elif args.command == "build":
        sys.exit(cmd_build(args))
    elif args.command == "spawn-standing":
        sys.exit(cmd_spawn_standing(args))
    elif args.command == "list-standing":
        sys.exit(cmd_list_standing(args))


if __name__ == "__main__":
    main()
