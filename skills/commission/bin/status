#!/usr/bin/env python3
# commissioned-by: spacedock@{spacedock_version}
# ABOUTME: Workflow status viewer — shows entity overview from YAML frontmatter.
# ABOUTME: Supports default table, --archived, --next, --next-id, --boot, and --discover.
#
# goal: Show one-line-per-{entity_label} workflow overview from YAML frontmatter.
#
# instruction: For every .md file in this directory (excluding README.md),
#   extract slug (filename without .md), id, status, title, score, source from YAML frontmatter.
#   Print aligned table with columns: ID, SLUG, STATUS, TITLE, SCORE, SOURCE.
#   Sorted by stage order ascending, then score descending.
#   Default: scan only $DIR/*.md. With --archived, also scan $DIR/_archive/*.md.
#   With --next, read stage metadata from README frontmatter and output dispatchable entities.
#   With --next-id, print only the next sequential ID across active and archived entities.
#
# --where filters: Supply one or more --where clauses to filter the output.
#   Accepted forms (operators `=` and `!=` only, with or without spaces around the operator):
#     --where "status = watching"      (equality, spaced)
#     --where "status=watching"        (equality, unspaced)
#     --where "status != done"         (negation, spaced)
#     --where "status!=done"           (negation, unspaced)
#     --where "pr !="                  (presence — field is non-empty)
#     --where "pr ="                   (absence — field is empty)
#   Multiple --where clauses AND together. Works on any frontmatter field, including
#   custom fields. Bare field names without an operator are rejected with an error.
#   Field names and values are case-sensitive.
#
# --fields / --all-fields (append extra frontmatter columns):
#   --fields a,b,c    append fields a, b, c as extra columns in the order listed.
#   --all-fields      append every non-empty frontmatter field (minus default columns)
#                     in sorted order.
#   Both flags append — they do not replace — the default column set, and both work
#   with the default table and the --next table. Missing, empty, or nonexistent
#   fields render as blank. The two flags are mutually exclusive, and neither can be
#   combined with --boot or --set.
#
# --archive <slug>: Move {workflow_dir}/{slug}.md to {workflow_dir}/_archive/{slug}.md,
#   creating _archive/ if missing, stamping `archived: <ISO-8601 UTC>` in frontmatter
#   before the move. Errors if the source is missing or the destination already exists.
#   Does not touch `completed`. Does not run git — the caller handles commits.
#
# YAML parsing: Read lines between the first and second "---" delimiters.
#   For each field, split on first ":" to get key and value.
#   This handles both "field: value" and "field:" (empty). No PyYAML dependency.
#
# Empty field handling: YAML frontmatter fields may be empty (e.g., "score:" with nothing
#   after the colon). After extraction, empty fields yield an empty string.
#   Display empty fields as blank (empty string), NOT as "-" or "0" or the field name.
#   For sort purposes, treat empty scores as lowest priority (sort after all scored items).
#
# Stage ordering: Map each status to a numeric order from the stages list.
#   Unknown statuses get order 99 (sort last).
#
# Output format: Use fixed column widths. Header row, then separator row
#   of dashes, then data rows.
#
# --next dispatch rules: An entity is dispatchable if ALL of:
#   1. Not terminal — its current stage has a defined next stage
#   2. Not gate-blocked — its current stage does NOT have gate: true
#   3. Not actively worked — entity does NOT have a non-empty worktree field
#   4. Concurrency available — count of actively-worked entities (non-empty worktree) in the next stage < that stage's concurrency limit
#
# constraints: Python 3 stdlib only (no PyYAML), resolves paths relative to this script, skips README.md.
# valid status values: {stage1}, {stage2}, ..., {last_stage}.

import glob
import os
import subprocess
import sys
from datetime import datetime, timezone


def parse_frontmatter(filepath):
    """Extract YAML frontmatter fields from a markdown file."""
    fields = {}
    in_fm = False
    with open(filepath, 'r') as f:
        for line in f:
            line = line.rstrip('\n')
            if line == '---':
                if in_fm:
                    break
                in_fm = True
                continue
            if in_fm:
                if ':' in line:
                    key, _, val = line.partition(':')
                    key = key.strip()
                    val = val.strip()
                    if len(val) >= 2 and val[0] == val[-1] and val[0] in ('"', "'"):
                        val = val[1:-1]
                    if not line[0].isspace():
                        fields[key] = val
    return fields


def parse_stages_block(filepath):
    """Parse the stages block from README frontmatter."""
    lines = []
    in_fm = False
    with open(filepath, 'r') as f:
        for line in f:
            line = line.rstrip('\n')
            if line == '---':
                if in_fm:
                    break
                in_fm = True
                continue
            if in_fm:
                lines.append(line)

    stages_start = None
    for i, line in enumerate(lines):
        if line.rstrip() == 'stages:':
            stages_start = i
            break

    if stages_start is None:
        return None

    defaults = {}
    states = []
    i = stages_start + 1
    stages_indent = None
    while i < len(lines):
        line = lines[i]
        stripped = line.lstrip()
        if not stripped:
            i += 1
            continue
        indent = len(line) - len(stripped)
        if stages_indent is None:
            stages_indent = indent
        elif indent < stages_indent:
            break

        if indent == stages_indent:
            if stripped == 'defaults:':
                i += 1
                while i < len(lines):
                    dline = lines[i]
                    dstripped = dline.lstrip()
                    if not dstripped:
                        i += 1
                        continue
                    dindent = len(dline) - len(dstripped)
                    if dindent <= stages_indent:
                        break
                    if ':' in dstripped:
                        k, _, v = dstripped.partition(':')
                        defaults[k.strip()] = v.strip()
                    i += 1
                continue
            elif stripped == 'states:':
                i += 1
                current_state = None
                while i < len(lines):
                    sline = lines[i]
                    sstripped = sline.lstrip()
                    if not sstripped:
                        i += 1
                        continue
                    sindent = len(sline) - len(sstripped)
                    if sindent <= stages_indent:
                        break
                    if sstripped.startswith('- name:'):
                        _, _, name = sstripped.partition('- name:')
                        current_state = {'name': name.strip()}
                        states.append(current_state)
                    elif current_state is not None and ':' in sstripped and not sstripped.startswith('- '):
                        k, _, v = sstripped.partition(':')
                        current_state[k.strip()] = v.strip()
                    i += 1
                continue
        i += 1

    if not states:
        return None

    default_worktree = defaults.get('worktree', 'false').lower() == 'true'
    default_concurrency = int(defaults.get('concurrency', '2'))

    result = []
    for state in states:
        stage = {
            'name': state['name'],
            'worktree': state.get('worktree', str(default_worktree)).lower() == 'true',
            'concurrency': int(state.get('concurrency', str(default_concurrency))),
            'gate': state.get('gate', 'false').lower() == 'true',
            'terminal': state.get('terminal', 'false').lower() == 'true',
            'initial': state.get('initial', 'false').lower() == 'true',
        }
        for optional_field in ('feedback-to', 'agent', 'fresh'):
            if optional_field in state:
                stage[optional_field] = state[optional_field]
        result.append(stage)

    return result


def scan_entities(directory):
    """Scan a directory for .md entity files (excluding README.md)."""
    entities = []
    pattern = os.path.join(directory, '*.md')
    for filepath in sorted(glob.glob(pattern)):
        if os.path.basename(filepath) == 'README.md':
            continue
        slug = os.path.splitext(os.path.basename(filepath))[0]
        fields = parse_frontmatter(filepath)
        entity = {k: v for k, v in fields.items()}
        entity['slug'] = slug
        for key in ('id', 'status', 'title', 'score', 'source', 'worktree'):
            entity.setdefault(key, '')
        entities.append(entity)
    return entities


def resolve_active_entity_path(entity_path, git_root):
    """Resolve to the active worktree copy when an entity is worktree-backed."""
    fields = parse_frontmatter(entity_path)
    worktree = fields.get('worktree', '').strip()
    if not worktree:
        return entity_path

    filename = os.path.basename(entity_path)
    worktree_entity_path = os.path.join(git_root, worktree, filename)
    if os.path.exists(worktree_entity_path):
        return worktree_entity_path
    return entity_path


def load_active_entity_fields(entity_path, git_root):
    """Load entity fields from the active worktree copy, overlaying main metadata."""
    fields = parse_frontmatter(entity_path)
    worktree = fields.get('worktree', '').strip()
    if not worktree:
        return fields

    filename = os.path.basename(entity_path)
    worktree_entity_path = os.path.join(git_root, worktree, filename)
    if not os.path.exists(worktree_entity_path):
        return fields

    active_fields = parse_frontmatter(worktree_entity_path)
    merged = dict(fields)
    merged.update(active_fields)
    return merged


def scan_entities_active(directory, git_root):
    """Scan entities, reading active worktree-backed entities from their worktree copy."""
    entities = []
    pattern = os.path.join(directory, '*.md')
    for filepath in sorted(glob.glob(pattern)):
        if os.path.basename(filepath) == 'README.md':
            continue
        slug = os.path.splitext(os.path.basename(filepath))[0]
        fields = load_active_entity_fields(filepath, git_root)
        entity = {k: v for k, v in fields.items()}
        entity['slug'] = slug
        for key in ('id', 'status', 'title', 'score', 'source', 'worktree'):
            entity.setdefault(key, '')
        entities.append(entity)
    return entities


def stage_order(status, stages):
    """Map status to numeric order based on stages list. Unknown = 99."""
    if stages:
        for i, stage in enumerate(stages):
            if stage['name'] == status:
                return i + 1
    return 99


def sort_key_default(entity, stages):
    """Sort key for default mode: stage order ascending, score descending."""
    order = stage_order(entity['status'], stages)
    score_str = entity['score']
    if score_str:
        try:
            score_val = -float(score_str)
        except ValueError:
            score_val = 0
    else:
        score_val = 1
    return (order, score_val)


def sort_key_next(entity):
    """Sort key for --next mode: score descending."""
    score_str = entity['score']
    if score_str:
        try:
            return -float(score_str)
        except ValueError:
            return 0
    return 1


def print_status_table(entities, stages, extra_fields=None):
    """Print the default status table, optionally with extra frontmatter columns."""
    extras = list(extra_fields or [])
    base_fmt = '%-6s %-30s %-20s %-30s %-8s %s'
    sorted_entities = sorted(entities, key=lambda e: sort_key_default(e, stages))

    if not extras:
        print(base_fmt % ('ID', 'SLUG', 'STATUS', 'TITLE', 'SCORE', 'SOURCE'))
        print(base_fmt % ('--', '----', '------', '-----', '-----', '------'))
        for e in sorted_entities:
            print(base_fmt % (
                e['id'], e['slug'], e['status'], e['title'], e['score'], e['source']
            ))
        return

    # SOURCE column is the last %s in base_fmt and has no trailing width, so
    # pad it when extra columns follow so the extras line up.
    base_cells_fmt = '%-6s %-30s %-20s %-30s %-8s %-30s'
    # Extras after the last column — last extra has no trailing width.
    extra_fmt_parts = ['%-20s'] * (len(extras) - 1) + ['%s']
    row_fmt = base_cells_fmt + ' ' + ' '.join(extra_fmt_parts)

    header_extras = [name.upper() for name in extras]
    sep_extras = ['-' * min(len(name), 20) for name in header_extras]
    print(row_fmt % ('ID', 'SLUG', 'STATUS', 'TITLE', 'SCORE', 'SOURCE', *header_extras))
    print(row_fmt % ('--', '----', '------', '-----', '-----', '------', *sep_extras))
    for e in sorted_entities:
        extra_cells = [format_extra_cell(e.get(name, '')) for name in extras]
        print(row_fmt % (
            e['id'], e['slug'], e['status'], e['title'], e['score'], e['source'],
            *extra_cells,
        ))


def print_next_table(entities, stages, extra_fields=None):
    """Print the --next dispatchable entities table, optionally with extras."""
    extras = list(extra_fields or [])
    stage_by_name = {s['name']: s for s in stages}
    stage_names = [s['name'] for s in stages]
    active_counts = {}
    for e in entities:
        if e['worktree']:
            st = e['status']
            active_counts[st] = active_counts.get(st, 0) + 1

    candidates = sorted(entities, key=sort_key_next)
    next_stage_counts = dict(active_counts)
    dispatchable = []
    for e in candidates:
        status = e['status']
        if status not in stage_by_name:
            continue
        stage_idx = stage_names.index(status)
        stage = stage_by_name[status]
        if stage.get('terminal', False):
            continue
        if stage.get('gate', False):
            continue
        if e['worktree']:
            continue
        if stage_idx + 1 >= len(stage_names):
            continue
        next_stage_name = stage_names[stage_idx + 1]
        next_stage = stage_by_name[next_stage_name]
        current_count = next_stage_counts.get(next_stage_name, 0)
        if current_count >= next_stage['concurrency']:
            continue
        next_stage_counts[next_stage_name] = current_count + 1
        dispatchable.append({
            **e,
            'next': next_stage_name,
            'next_worktree': 'yes' if next_stage['worktree'] else 'no',
        })

    if not extras:
        fmt = '%-6s %-30s %-20s %-20s %s'
        print(fmt % ('ID', 'SLUG', 'CURRENT', 'NEXT', 'WORKTREE'))
        print(fmt % ('--', '----', '-------', '----', '--------'))
        for e in dispatchable:
            print(fmt % (e['id'], e['slug'], e['status'], e['next'], e['next_worktree']))
        return

    base_cells_fmt = '%-6s %-30s %-20s %-20s %-8s'
    extra_fmt_parts = ['%-20s'] * (len(extras) - 1) + ['%s']
    row_fmt = base_cells_fmt + ' ' + ' '.join(extra_fmt_parts)
    header_extras = [name.upper() for name in extras]
    sep_extras = ['-' * min(len(name), 20) for name in header_extras]
    print(row_fmt % ('ID', 'SLUG', 'CURRENT', 'NEXT', 'WORKTREE', *header_extras))
    print(row_fmt % ('--', '----', '-------', '----', '--------', *sep_extras))
    for e in dispatchable:
        extra_cells = [format_extra_cell(e.get(name, '')) for name in extras]
        print(row_fmt % (
            e['id'], e['slug'], e['status'], e['next'], e['next_worktree'],
            *extra_cells,
        ))


def scan_mods(workflow_dir):
    """Scan _mods/*.md for ## Hook: headings, return {hook_point: [mod_names]} mapping."""
    mods_dir = os.path.join(workflow_dir, '_mods')
    if not os.path.isdir(mods_dir):
        return {}
    hooks = {}
    for filepath in sorted(glob.glob(os.path.join(mods_dir, '*.md'))):
        mod_name = os.path.splitext(os.path.basename(filepath))[0]
        with open(filepath, 'r') as f:
            for line in f:
                line = line.rstrip('\n')
                if line.startswith('## Hook:'):
                    point = line[len('## Hook:'):].strip()
                    if point:
                        hooks.setdefault(point, []).append(mod_name)
    return hooks


def compute_next_id(active_entities, archive_dir):
    """Find the highest numeric ID across active + archived entities, return next ID string."""
    max_id = 0
    all_entities = list(active_entities)
    if os.path.isdir(archive_dir):
        all_entities.extend(scan_entities(archive_dir))
    for e in all_entities:
        id_str = e.get('id', '')
        if id_str:
            try:
                id_num = int(id_str)
                if id_num > max_id:
                    max_id = id_num
            except ValueError:
                pass
    return '%03d' % (max_id + 1)


def print_next_id(entities, workflow_dir):
    """Print only the next sequential ID."""
    archive_dir = os.path.join(workflow_dir, '_archive')
    print(compute_next_id(entities, archive_dir))


def scan_orphans(entities, git_root):
    """Return entities with non-empty worktree field, with dir/branch existence info."""
    worktree_paths = {}
    try:
        result = subprocess.run(
            ['git', 'worktree', 'list', '--porcelain'],
            capture_output=True, text=True, cwd=git_root
        )
        if result.returncode == 0:
            current_path = None
            for line in result.stdout.split('\n'):
                if line.startswith('worktree '):
                    current_path = line[len('worktree '):].strip()
                elif line.startswith('branch ') and current_path is not None:
                    worktree_paths[os.path.realpath(current_path)] = True
                elif line == '':
                    current_path = None
    except FileNotFoundError:
        pass

    orphans = []
    for e in entities:
        wt = e.get('worktree', '')
        if not wt:
            continue
        dir_path = os.path.join(git_root, wt)
        dir_exists = 'yes' if os.path.isdir(dir_path) else 'no'
        branch_exists = 'yes' if os.path.realpath(dir_path) in worktree_paths else 'no'
        orphans.append({
            'id': e.get('id', ''),
            'slug': e.get('slug', ''),
            'worktree': wt,
            'dir_exists': dir_exists,
            'branch_exists': branch_exists,
        })
    return orphans


def check_pr_states(entities, stages):
    """Check PR state for entities with non-empty pr and non-terminal status."""
    stage_by_name = {s['name']: s for s in stages}
    pr_entities = []
    for e in entities:
        pr = e.get('pr', '')
        if not pr:
            continue
        status = e.get('status', '')
        stage = stage_by_name.get(status)
        if stage and stage.get('terminal', False):
            continue
        pr_entities.append(e)

    if not pr_entities:
        return 'none', []

    # Check if gh is available
    gh_path = None
    for d in os.environ.get('PATH', '').split(os.pathsep):
        candidate = os.path.join(d, 'gh')
        if os.path.isfile(candidate) and os.access(candidate, os.X_OK):
            gh_path = candidate
            break
    if gh_path is None:
        return 'gh not available', []

    results = []
    for e in pr_entities:
        pr = e.get('pr', '').lstrip('#')
        try:
            result = subprocess.run(
                ['gh', 'pr', 'view', pr, '--json', 'state', '--jq', '.state'],
                capture_output=True, text=True
            )
            if result.returncode == 0:
                state = result.stdout.strip().upper()
            else:
                state = 'ERROR'
        except FileNotFoundError:
            state = 'ERROR'
        results.append({
            'id': e.get('id', ''),
            'slug': e.get('slug', ''),
            'pr': e.get('pr', ''),
            'state': state,
        })
    return 'ok', results


def print_boot(entities, stages, workflow_dir, git_root):
    """Print all boot sections: MODS, NEXT_ID, ORPHANS, PR_STATE, DISPATCHABLE."""
    # MODS
    hooks = scan_mods(workflow_dir)
    if not hooks:
        print('MODS: none')
    else:
        print('MODS')
        for point in sorted(hooks.keys()):
            mods = ', '.join(sorted(hooks[point]))
            print('%s: %s' % (point, mods))

    # NEXT_ID
    archive_dir = os.path.join(workflow_dir, '_archive')
    next_id = compute_next_id(entities, archive_dir)
    print('NEXT_ID: %s' % next_id)

    # ORPHANS
    orphans = scan_orphans(entities, git_root)
    if not orphans:
        print('ORPHANS: none')
    else:
        print('ORPHANS')
        fmt = '%-6s %-30s %-43s %-11s %s'
        print(fmt % ('ID', 'SLUG', 'WORKTREE', 'DIR_EXISTS', 'BRANCH_EXISTS'))
        for o in orphans:
            print(fmt % (o['id'], o['slug'], o['worktree'], o['dir_exists'], o['branch_exists']))

    # PR_STATE
    pr_status, pr_results = check_pr_states(entities, stages)
    if pr_status == 'none':
        print('PR_STATE: none')
    elif pr_status == 'gh not available':
        print('PR_STATE: gh not available')
    else:
        print('PR_STATE')
        fmt = '%-6s %-30s %-8s %s'
        print(fmt % ('ID', 'SLUG', 'PR', 'STATE'))
        for r in pr_results:
            print(fmt % (r['id'], r['slug'], r['pr'], r['state']))

    # DISPATCHABLE
    print('DISPATCHABLE')
    print_next_table(entities, stages)


WHERE_SYNTAX_HELP = (
    "--where requires an operator: use 'field = value', 'field != value', "
    "'field !=' (non-empty), or 'field =' (empty)"
)


def parse_where_filters(args):
    """Parse --where arguments from sys.argv.

    Accepts equality (`=`) and negation (`!=`) with or without whitespace
    around the operator. Presence checks are expressed as `field !=` (non-empty)
    and `field =` (empty). Bare field names are rejected with an error that
    names the four valid forms. `!=` is matched before `=` to prevent a single
    `=` search from slicing inside the two-character `!=` operator.
    """
    filters = []
    i = 0
    while i < len(args):
        if args[i] == '--where':
            if i + 1 >= len(args):
                raise ValueError('--where requires an argument')
            where_arg = args[i + 1]
            if not where_arg.strip():
                raise ValueError('--where argument cannot be empty')

            # Operator precedence: check for `!=` first, then `=`. Splitting on
            # the first `=` in a string like `worktree !=` would slice the
            # operator itself and mis-classify negation as equality.
            if '!=' in where_arg:
                op = '!='
                field_part, _, value_part = where_arg.partition('!=')
            elif '=' in where_arg:
                op = '='
                field_part, _, value_part = where_arg.partition('=')
            else:
                raise ValueError(WHERE_SYNTAX_HELP)

            field = field_part.strip()
            if not field:
                raise ValueError(WHERE_SYNTAX_HELP)

            value = value_part.strip()
            if value == '':
                value = None

            filters.append((field, op, value))
            i += 2
        else:
            i += 1
    return filters


def parse_workflow_dir(args):
    """Extract --workflow-dir from argv and return (workflow_dir, remaining_args)."""
    remaining = []
    workflow_dir = None
    i = 0
    while i < len(args):
        if args[i] == '--workflow-dir':
            if i + 1 >= len(args):
                raise ValueError('--workflow-dir requires an argument')
            workflow_dir = args[i + 1]
            i += 2
            continue
        remaining.append(args[i])
        i += 1
    return workflow_dir, remaining


def parse_fields_options(args):
    """Parse --fields and --all-fields from argv.

    Returns (explicit_fields, all_fields_flag) where explicit_fields is a list
    of field names in user order (deduped) or None, and all_fields_flag is a
    bool. Raises ValueError if both flags are supplied together, or if
    --fields has no argument / an empty argument.
    """
    explicit_fields = None
    all_fields_flag = False
    i = 0
    while i < len(args):
        if args[i] == '--fields':
            if i + 1 >= len(args):
                raise ValueError('--fields requires a comma-separated list of field names')
            raw = args[i + 1]
            if not raw.strip():
                raise ValueError('--fields requires a comma-separated list of field names')
            parsed = []
            seen = set()
            for name in raw.split(','):
                name = name.strip()
                if not name:
                    continue
                if name in seen:
                    continue
                seen.add(name)
                parsed.append(name)
            if not parsed:
                raise ValueError('--fields requires a comma-separated list of field names')
            explicit_fields = parsed
            i += 2
            continue
        if args[i] == '--all-fields':
            all_fields_flag = True
            i += 1
            continue
        i += 1

    if explicit_fields is not None and all_fields_flag:
        raise ValueError('--fields and --all-fields are mutually exclusive')

    return explicit_fields, all_fields_flag


def parse_archive_arg(args):
    """Parse --archive <slug> from argv. Returns slug or None."""
    i = 0
    while i < len(args):
        if args[i] == '--archive':
            if i + 1 >= len(args):
                raise ValueError('--archive requires a slug argument')
            slug = args[i + 1]
            if not slug or slug.startswith('--'):
                raise ValueError('--archive requires a slug argument')
            return slug
        i += 1
    return None


DEFAULT_STATUS_FIELDS = ('id', 'slug', 'status', 'title', 'score', 'source')
DEFAULT_NEXT_FIELDS = ('id', 'slug', 'status')


def resolve_extra_fields(entities, explicit_fields, all_fields_flag, default_fields):
    """Return the list of extra frontmatter field names to append as columns.

    `explicit_fields` (if non-None) is used verbatim in user order.
    `all_fields_flag` collects every non-empty frontmatter key across `entities`,
    drops anything already in `default_fields`, and returns the remainder sorted.
    """
    if explicit_fields is not None:
        return list(explicit_fields)
    if all_fields_flag:
        defaults = set(default_fields)
        seen = set()
        for e in entities:
            for key, val in e.items():
                if key in defaults:
                    continue
                if val == '' or val is None:
                    continue
                seen.add(key)
        return sorted(seen)
    return []


def format_extra_cell(value, width=20):
    """Render an extra-column cell: blank for missing/empty, truncate with ellipsis."""
    if value is None:
        value = ''
    value = str(value)
    if len(value) > width:
        return value[:width - 1] + '\u2026'
    return value


TIMESTAMP_FIELDS = {'started', 'completed'}


def parse_set_args(args):
    """Parse --set arguments, returning (slug, field_updates) or None.

    field_updates is a list of (field, value) tuples where value is:
    - a string for explicit field=value
    - '' for field= (clear)
    - None for bare timestamp fields (auto-fill with now())
    """
    i = 0
    while i < len(args):
        if args[i] == '--set':
            if i + 1 >= len(args):
                raise ValueError('--set requires a slug argument')
            slug = args[i + 1]
            updates = []
            j = i + 2
            while j < len(args) and not args[j].startswith('--'):
                arg = args[j]
                if '=' in arg:
                    field, _, value = arg.partition('=')
                    updates.append((field, value))
                elif arg in TIMESTAMP_FIELDS:
                    updates.append((arg, None))
                else:
                    raise ValueError(
                        f"bare field '{arg}' requires a value (use {arg}=value); "
                        f"only {', '.join(sorted(TIMESTAMP_FIELDS))} support auto-fill"
                    )
                j += 1
            if not updates:
                raise ValueError('--set requires at least one field=value argument')
            return slug, updates
        i += 1
    return None


def update_frontmatter(filepath, updates):
    """Rewrite frontmatter fields in a file. Returns dict of updated fields."""
    with open(filepath, 'r') as f:
        content = f.read()

    lines = content.split('\n')
    in_fm = False
    fm_start = None
    fm_end = None
    for i, line in enumerate(lines):
        if line.rstrip() == '---':
            if not in_fm:
                in_fm = True
                fm_start = i
            else:
                fm_end = i
                break

    if fm_start is None or fm_end is None:
        raise ValueError(f'No frontmatter found in {filepath}')

    # Read current values to support skip-if-set for timestamp fields
    current_values = {}
    for i in range(fm_start + 1, fm_end):
        line = lines[i]
        if ':' in line and not line[0].isspace():
            key, _, val = line.partition(':')
            current_values[key.strip()] = val.strip()

    # Resolve auto-fill timestamps
    resolved = {}
    now_str = datetime.now(timezone.utc).strftime('%Y-%m-%dT%H:%M:%SZ')
    for field, value in updates:
        if value is None:
            # Bare timestamp field — skip if already has a value
            if current_values.get(field, ''):
                continue
            resolved[field] = now_str
        else:
            resolved[field] = value

    # Rewrite matching lines in frontmatter
    written = set()
    for i in range(fm_start + 1, fm_end):
        line = lines[i]
        if ':' in line and not line[0].isspace():
            key, _, _ = line.partition(':')
            key_stripped = key.strip()
            if key_stripped in resolved:
                lines[i] = f'{key_stripped}: {resolved[key_stripped]}'
                written.add(key_stripped)

    # Insert fields not already present in frontmatter before closing ---
    missing = [f for f in resolved if f not in written]
    for field in missing:
        lines.insert(fm_end, f'{field}: {resolved[field]}')
        fm_end += 1

    with open(filepath, 'w') as f:
        f.write('\n'.join(lines))

    return resolved


def apply_filters(entities, filters):
    """Filter entities based on --where conditions."""
    if not filters:
        return entities
    filtered = []
    for e in entities:
        match = True
        for field, op, value in filters:
            field_val = e.get(field, '')
            if op == '!=':
                if value is None:
                    if not field_val:
                        match = False
                        break
                else:
                    if field_val == value:
                        match = False
                        break
            elif op == '=':
                if value is None:
                    if field_val:
                        match = False
                        break
                else:
                    if field_val != value:
                        match = False
                        break
        if match:
            filtered.append(e)
    return filtered


def run_archive(pipeline_dir, slug, force=False):
    """Move {pipeline_dir}/{slug}.md to {pipeline_dir}/_archive/{slug}.md.

    Stamps `archived: <ISO-8601 UTC>` in the frontmatter before moving, using
    the same `update_frontmatter()` insert-if-missing path that `--set` uses.
    Does not touch `completed`. Does not run git — the caller handles commits.
    Errors if the source is missing or the destination already exists.
    """
    source_path = os.path.join(pipeline_dir, slug + '.md')
    if not os.path.exists(source_path):
        print(f'Error: entity not found: {slug}.md', file=sys.stderr)
        sys.exit(1)

    # Mod-block guard: refuse archival while mod-block is active
    fields = parse_frontmatter(source_path)
    mod_block = fields.get('mod-block', '').strip()
    pr = fields.get('pr', '').strip()
    if mod_block:
        if not force:
            print(f'Error: entity {slug} has pending mod-block ({mod_block}). '
                  f'Use --force to override.', file=sys.stderr)
            sys.exit(1)
        print(f'Warning: --force overriding mod-block ({mod_block}) on entity {slug}',
              file=sys.stderr)

    # Merge-hook invariant: archival is a terminal action. When the workflow
    # registers a merge hook, refuse archival unless the hook has run (pr set),
    # the hook is in flight (mod-block set, already handled above), or --force.
    if not force and not mod_block and not pr:
        merge_hooks = scan_mods(pipeline_dir).get('merge', [])
        if merge_hooks:
            hook_list = ', '.join(merge_hooks)
            print(
                f'Error: entity {slug} cannot be archived — workflow has merge '
                f'hook(s) [{hook_list}] that have not run (pr field is empty and '
                f'mod-block is empty). Invoke the hook first, or use --force to bypass.',
                file=sys.stderr,
            )
            sys.exit(1)

    archive_dir = os.path.join(pipeline_dir, '_archive')
    dest_path = os.path.join(archive_dir, slug + '.md')
    if os.path.exists(dest_path):
        print(f'Error: already archived: {slug}.md', file=sys.stderr)
        sys.exit(1)

    os.makedirs(archive_dir, exist_ok=True)

    now_str = datetime.now(timezone.utc).strftime('%Y-%m-%dT%H:%M:%SZ')
    try:
        update_frontmatter(source_path, [('archived', now_str)])
    except ValueError as e:
        print('Error: ' + str(e), file=sys.stderr)
        sys.exit(1)

    os.rename(source_path, dest_path)
    print(f'archived: {dest_path}')


def find_git_root(start_dir):
    """Walk up from start_dir to find the .git directory, return its parent."""
    d = os.path.abspath(start_dir)
    while True:
        if os.path.isdir(os.path.join(d, '.git')) or os.path.isfile(os.path.join(d, '.git')):
            return d
        parent = os.path.dirname(d)
        if parent == d:
            return start_dir
        d = parent


DISCOVER_IGNORE_DIRS = {'.git', '.worktrees', 'node_modules', 'vendor', 'dist', 'build', '__pycache__', 'tests'}


def discover_workflows(root):
    """Walk a directory tree and return workflow directories.

    A workflow directory is one containing a README.md whose YAML frontmatter
    has a ``commissioned-by`` field starting with ``spacedock@``.

    Matching rule:
        The ``commissioned-by`` value must start with the literal string
        ``spacedock@``. Both ``spacedock@1.0`` and bare ``spacedock@`` (no
        version suffix) are accepted.

    Ignored directories (pruned during walk — canonical source of truth):
        .git, .worktrees, node_modules, vendor, dist, build, __pycache__, tests

    Symlink handling:
        Symlinks are followed (``followlinks=True``). Paths are resolved with
        ``os.path.realpath`` before deduplication. When both a symlink and its
        target match, the canonical resolved (real) path is returned, not the
        symlink path. Visited real paths are tracked to avoid infinite loops
        from symlink cycles.

    Returns:
        Sorted list of absolute, resolved directory paths.
    """
    root = os.path.abspath(root)
    seen_real = set()
    results = []

    for dirpath, dirnames, filenames in os.walk(root, followlinks=True):
        real_dir = os.path.realpath(dirpath)
        if real_dir in seen_real:
            dirnames[:] = []
            continue
        seen_real.add(real_dir)

        dirnames[:] = [d for d in dirnames if d not in DISCOVER_IGNORE_DIRS]

        if 'README.md' not in filenames:
            continue

        readme_path = os.path.join(dirpath, 'README.md')
        try:
            fields = parse_frontmatter(readme_path)
        except (OSError, IOError):
            continue

        commissioned_by = fields.get('commissioned-by', '')
        if commissioned_by.startswith('spacedock@'):
            resolved = os.path.realpath(dirpath)
            if resolved not in {r for r in results}:
                results.append(resolved)

    return sorted(results)


def main():
    args = sys.argv[1:]

    # Handle --discover mode (incompatible with all other flags)
    if '--discover' in args:
        incompatible = [
            f for f in args if f in (
                '--boot', '--next', '--next-id', '--archived', '--where',
                '--set', '--archive', '--fields', '--all-fields', '--workflow-dir',
            )
        ]
        if incompatible:
            print('Error: --discover is incompatible with %s' % ', '.join(sorted(set(incompatible))),
                  file=sys.stderr)
            sys.exit(1)

        # Parse --root
        root_path = None
        i = 0
        while i < len(args):
            if args[i] == '--root':
                if i + 1 >= len(args):
                    print('Error: --root requires an argument', file=sys.stderr)
                    sys.exit(1)
                root_path = args[i + 1]
                i += 2
            else:
                i += 1

        if root_path is None:
            try:
                result = subprocess.run(
                    ['git', 'rev-parse', '--show-toplevel'],
                    capture_output=True, text=True,
                )
                if result.returncode == 0:
                    root_path = result.stdout.strip()
                else:
                    root_path = os.getcwd()
            except FileNotFoundError:
                root_path = os.getcwd()

        if not os.path.isdir(root_path):
            print('Error: --root path does not exist: %s' % root_path, file=sys.stderr)
            sys.exit(1)

        for path in discover_workflows(root_path):
            print(path)
        sys.exit(0)

    try:
        workflow_dir, args = parse_workflow_dir(args)
    except ValueError as e:
        print('Error: ' + str(e), file=sys.stderr)
        sys.exit(1)

    pipeline_dir = workflow_dir or os.environ.get('PIPELINE_DIR') or os.path.dirname(os.path.abspath(__file__))

    # Parse --set before other flags
    try:
        set_result = parse_set_args(args)
    except ValueError as e:
        print('Error: ' + str(e), file=sys.stderr)
        sys.exit(1)

    try:
        archive_slug = parse_archive_arg(args)
    except ValueError as e:
        print('Error: ' + str(e), file=sys.stderr)
        sys.exit(1)

    try:
        explicit_fields, all_fields_flag = parse_fields_options(args)
    except ValueError as e:
        print('Error: ' + str(e), file=sys.stderr)
        sys.exit(1)

    include_archive = '--archived' in args
    show_next = '--next' in args
    show_next_id = '--next-id' in args
    show_boot = '--boot' in args
    has_fields_flag = explicit_fields is not None or all_fields_flag

    # --boot is incompatible with --next, --next-id, --archived, --where, --fields, --all-fields
    if show_boot:
        if show_next:
            print('Error: --boot is incompatible with --next', file=sys.stderr)
            sys.exit(1)
        if show_next_id:
            print('Error: --boot is incompatible with --next-id', file=sys.stderr)
            sys.exit(1)
        if include_archive:
            print('Error: --boot is incompatible with --archived', file=sys.stderr)
            sys.exit(1)
        if has_fields_flag:
            print('Error: --boot is incompatible with --fields / --all-fields', file=sys.stderr)
            sys.exit(1)

    try:
        where_filters = parse_where_filters(args)
    except ValueError as e:
        print('Error: ' + str(e), file=sys.stderr)
        sys.exit(1)

    if show_boot and where_filters:
        print('Error: --boot is incompatible with --where', file=sys.stderr)
        sys.exit(1)

    if show_next_id:
        incompatible = []
        if show_next:
            incompatible.append('--next')
        if include_archive:
            incompatible.append('--archived')
        if show_boot:
            incompatible.append('--boot')
        if where_filters:
            incompatible.append('--where')
        if has_fields_flag:
            incompatible.append('--fields/--all-fields')
        if archive_slug is not None:
            incompatible.append('--archive')
        if set_result is not None:
            incompatible.append('--set')
        if incompatible:
            print(f'Error: --next-id cannot be combined with {", ".join(incompatible)}',
                  file=sys.stderr)
            sys.exit(1)

        entities = scan_entities(pipeline_dir)
        print_next_id(entities, pipeline_dir)
        sys.exit(0)

    if archive_slug is not None:
        incompatible = []
        if show_next:
            incompatible.append('--next')
        if include_archive:
            incompatible.append('--archived')
        if show_boot:
            incompatible.append('--boot')
        if show_next_id:
            incompatible.append('--next-id')
        if where_filters:
            incompatible.append('--where')
        if has_fields_flag:
            incompatible.append('--fields/--all-fields')
        if set_result is not None:
            incompatible.append('--set')
        if incompatible:
            print(f'Error: --archive cannot be combined with {", ".join(incompatible)}',
                  file=sys.stderr)
            sys.exit(1)

        run_archive(pipeline_dir, archive_slug, force='--force' in args)
        sys.exit(0)

    if set_result is not None:
        # Check for incompatible flags
        incompatible = []
        if show_next:
            incompatible.append('--next')
        if include_archive:
            incompatible.append('--archived')
        if show_boot:
            incompatible.append('--boot')
        if show_next_id:
            incompatible.append('--next-id')
        if where_filters:
            incompatible.append('--where')
        if has_fields_flag:
            incompatible.append('--fields/--all-fields')
        if incompatible:
            print(f'Error: --set cannot be combined with {", ".join(incompatible)}',
                  file=sys.stderr)
            sys.exit(1)

        slug, updates = set_result
        force = '--force' in args
        main_entity_path = os.path.join(pipeline_dir, slug + '.md')
        if not os.path.exists(main_entity_path):
            print(f'Error: entity not found: {slug}.md', file=sys.stderr)
            sys.exit(1)
        git_root = find_git_root(pipeline_dir)
        entity_path = resolve_active_entity_path(main_entity_path, git_root)

        # Mod-block guard: refuse terminal transitions while mod-block is active.
        # Also refuse terminal transitions combined with clearing mod-block in the
        # same --set call — the two operations must be separate so the clear gets
        # its own commit and any reviewer/session-resume can see the block was
        # resolved before terminalization began.
        current_fields = parse_frontmatter(entity_path)
        mod_block = current_fields.get('mod-block', '').strip()
        current_pr = current_fields.get('pr', '').strip()
        clearing_mod_block = any(
            field == 'mod-block' and value == '' for field, value in updates
        )

        readme_path = os.path.join(pipeline_dir, 'README.md')
        stages = parse_stages_block(readme_path) if os.path.exists(readme_path) else None
        terminal_names = {s['name'] for s in (stages or []) if s.get('terminal')}

        def is_terminal_update():
            """True when this --set applies any terminal field."""
            for field, value in updates:
                if field == 'status' and value in terminal_names:
                    return True
                if field in ('completed', 'verdict'):
                    return True
                if field == 'worktree' and value == '':
                    return True
            return False

        # Resolve the post-update pr value. The current pr counts unless this
        # --set itself sets it; `pr=` (clear) also counts as no pr.
        post_update_pr = current_pr
        for field, value in updates:
            if field == 'pr':
                post_update_pr = value.strip()

        if (mod_block or clearing_mod_block) and not force:
            if is_terminal_update():
                if mod_block and not clearing_mod_block:
                    reason = f'pending mod-block ({mod_block})'
                elif clearing_mod_block:
                    # Either the block is currently set and the caller is clearing
                    # it in the same call, or the caller redundantly cleared an
                    # already-empty field alongside a terminal update. Either way
                    # the combined operation is rejected to keep the clear commit
                    # separate from the terminal commit.
                    reason = (
                        f'combined mod-block clear with terminal transition '
                        f'(current mod-block={mod_block!r})'
                    )
                else:
                    reason = 'mod-block transition'
                print(f'Error: entity {slug} has {reason}. '
                      f'Clear mod-block in a separate --set call, or use --force.',
                      file=sys.stderr)
                sys.exit(1)

        # Merge-hook invariant: when the workflow registers a merge hook, the
        # terminal transition must happen *after* that hook has run. We detect
        # hook completion by requiring a non-empty pr, a set mod-block (hook
        # in flight), or --force. If none of those hold, the FO is trying to
        # skip the hook entirely — refuse so the hook cannot be bypassed.
        if not force and is_terminal_update() and not mod_block and not post_update_pr:
            merge_hooks = scan_mods(pipeline_dir).get('merge', [])
            if merge_hooks:
                hook_list = ', '.join(merge_hooks)
                print(
                    f'Error: entity {slug} cannot advance to terminal — workflow '
                    f'has merge hook(s) [{hook_list}] that have not run (pr field '
                    f'is empty and mod-block is empty). Set mod-block=merge:{merge_hooks[0]} '
                    f'and invoke the hook, or use --force to bypass.',
                    file=sys.stderr,
                )
                sys.exit(1)

        if force and mod_block:
            print(f'Warning: --force overriding mod-block ({mod_block}) on entity {slug}',
                  file=sys.stderr)

        try:
            resolved = update_frontmatter(entity_path, updates)
            # Mirror PR metadata back to main for discovery, but keep all
            # other active-state updates on the worktree copy.
            if entity_path != main_entity_path:
                pr_updates = [(field, value) for field, value in updates if field == 'pr']
                if pr_updates:
                    update_frontmatter(main_entity_path, pr_updates)
        except ValueError as e:
            print('Error: ' + str(e), file=sys.stderr)
            sys.exit(1)

        for field, value in resolved.items():
            print(f'{field}: {value}')
        sys.exit(0)

    readme_path = os.path.join(pipeline_dir, 'README.md')
    stages = None
    if os.path.exists(readme_path):
        stages = parse_stages_block(readme_path)

    if show_next and stages is None:
        print('Error: README.md has no stages block. --next requires stage metadata.', file=sys.stderr)
        sys.exit(1)

    if show_boot and stages is None:
        print('Error: README.md has no stages block. --boot requires stage metadata.', file=sys.stderr)
        sys.exit(1)

    git_root = find_git_root(pipeline_dir)
    entities = scan_entities_active(pipeline_dir, git_root)
    if include_archive:
        archive_dir = os.path.join(pipeline_dir, '_archive')
        if os.path.isdir(archive_dir):
            entities.extend(scan_entities(archive_dir))

    entities = apply_filters(entities, where_filters)

    if show_boot:
        print_boot(entities, stages, pipeline_dir, git_root)
    elif show_next:
        extras = resolve_extra_fields(entities, explicit_fields, all_fields_flag, DEFAULT_NEXT_FIELDS)
        print_next_table(entities, stages, extra_fields=extras)
    else:
        extras = resolve_extra_fields(entities, explicit_fields, all_fields_flag, DEFAULT_STATUS_FIELDS)
        print_status_table(entities, stages, extra_fields=extras)


if __name__ == '__main__':
    main()
