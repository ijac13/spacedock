#!/usr/bin/env python3
# commissioned-by: spacedock@{spacedock_version}
# ABOUTME: Workflow status viewer — shows entity overview from YAML frontmatter.
# ABOUTME: Supports default table, --archived, --next, and --boot (FO startup data).
#
# goal: Show one-line-per-{entity_label} workflow overview from YAML frontmatter.
#
# instruction: For every .md file in this directory (excluding README.md),
#   extract slug (filename without .md), id, status, title, score, source from YAML frontmatter.
#   Print aligned table with columns: ID, SLUG, STATUS, TITLE, SCORE, SOURCE.
#   Sorted by stage order ascending, then score descending.
#   Default: scan only $DIR/*.md. With --archived, also scan $DIR/_archive/*.md.
#   With --next, read stage metadata from README frontmatter and output dispatchable entities.
#
# YAML parsing: Read lines between the first and second "---" delimiters.
#   For each field, split on first ":" to get key and value.
#   This handles both "field: value" and "field:" (empty). No PyYAML dependency.
#
# Empty field handling: YAML frontmatter fields may be empty (e.g., "score:" with nothing
#   after the colon). After extraction, empty fields yield an empty string.
#   Display empty fields as blank (empty string), NOT as "-" or "0" or the field name.
#   For sort purposes, treat empty scores as lowest priority (sort after all scored items).
#
# Stage ordering: Map each status to a numeric order from the stages list.
#   Unknown statuses get order 99 (sort last).
#
# Output format: Use fixed column widths. Header row, then separator row
#   of dashes, then data rows.
#
# --next dispatch rules: An entity is dispatchable if ALL of:
#   1. Not terminal — its current stage has a defined next stage
#   2. Not gate-blocked — its current stage does NOT have gate: true
#   3. Not actively worked — entity does NOT have a non-empty worktree field
#   4. Concurrency available — count of actively-worked entities (non-empty worktree) in the next stage < that stage's concurrency limit
#
# constraints: Python 3 stdlib only (no PyYAML), resolves paths relative to this script, skips README.md.
# valid status values: {stage1}, {stage2}, ..., {last_stage}.

import glob
import os
import subprocess
import sys
from datetime import datetime, timezone


def parse_frontmatter(filepath):
    """Extract YAML frontmatter fields from a markdown file."""
    fields = {}
    in_fm = False
    with open(filepath, 'r') as f:
        for line in f:
            line = line.rstrip('\n')
            if line == '---':
                if in_fm:
                    break
                in_fm = True
                continue
            if in_fm:
                if ':' in line:
                    key, _, val = line.partition(':')
                    key = key.strip()
                    val = val.strip()
                    if len(val) >= 2 and val[0] == val[-1] and val[0] in ('"', "'"):
                        val = val[1:-1]
                    if not line[0].isspace():
                        fields[key] = val
    return fields


def parse_stages_block(filepath):
    """Parse the stages block from README frontmatter."""
    lines = []
    in_fm = False
    with open(filepath, 'r') as f:
        for line in f:
            line = line.rstrip('\n')
            if line == '---':
                if in_fm:
                    break
                in_fm = True
                continue
            if in_fm:
                lines.append(line)

    stages_start = None
    for i, line in enumerate(lines):
        if line.rstrip() == 'stages:':
            stages_start = i
            break

    if stages_start is None:
        return None

    defaults = {}
    states = []
    i = stages_start + 1
    stages_indent = None
    while i < len(lines):
        line = lines[i]
        stripped = line.lstrip()
        if not stripped:
            i += 1
            continue
        indent = len(line) - len(stripped)
        if stages_indent is None:
            stages_indent = indent
        elif indent < stages_indent:
            break

        if indent == stages_indent:
            if stripped == 'defaults:':
                i += 1
                while i < len(lines):
                    dline = lines[i]
                    dstripped = dline.lstrip()
                    if not dstripped:
                        i += 1
                        continue
                    dindent = len(dline) - len(dstripped)
                    if dindent <= stages_indent:
                        break
                    if ':' in dstripped:
                        k, _, v = dstripped.partition(':')
                        defaults[k.strip()] = v.strip()
                    i += 1
                continue
            elif stripped == 'states:':
                i += 1
                current_state = None
                while i < len(lines):
                    sline = lines[i]
                    sstripped = sline.lstrip()
                    if not sstripped:
                        i += 1
                        continue
                    sindent = len(sline) - len(sstripped)
                    if sindent <= stages_indent:
                        break
                    if sstripped.startswith('- name:'):
                        _, _, name = sstripped.partition('- name:')
                        current_state = {'name': name.strip()}
                        states.append(current_state)
                    elif current_state is not None and ':' in sstripped and not sstripped.startswith('- '):
                        k, _, v = sstripped.partition(':')
                        current_state[k.strip()] = v.strip()
                    i += 1
                continue
        i += 1

    if not states:
        return None

    default_worktree = defaults.get('worktree', 'false').lower() == 'true'
    default_concurrency = int(defaults.get('concurrency', '2'))

    result = []
    for state in states:
        stage = {
            'name': state['name'],
            'worktree': state.get('worktree', str(default_worktree)).lower() == 'true',
            'concurrency': int(state.get('concurrency', str(default_concurrency))),
            'gate': state.get('gate', 'false').lower() == 'true',
            'terminal': state.get('terminal', 'false').lower() == 'true',
            'initial': state.get('initial', 'false').lower() == 'true',
        }
        result.append(stage)

    return result


def scan_entities(directory):
    """Scan a directory for .md entity files (excluding README.md)."""
    entities = []
    pattern = os.path.join(directory, '*.md')
    for filepath in sorted(glob.glob(pattern)):
        if os.path.basename(filepath) == 'README.md':
            continue
        slug = os.path.splitext(os.path.basename(filepath))[0]
        fields = parse_frontmatter(filepath)
        entity = {k: v for k, v in fields.items()}
        entity['slug'] = slug
        for key in ('id', 'status', 'title', 'score', 'source', 'worktree'):
            entity.setdefault(key, '')
        entities.append(entity)
    return entities


def stage_order(status, stages):
    """Map status to numeric order based on stages list. Unknown = 99."""
    if stages:
        for i, stage in enumerate(stages):
            if stage['name'] == status:
                return i + 1
    return 99


def sort_key_default(entity, stages):
    """Sort key for default mode: stage order ascending, score descending."""
    order = stage_order(entity['status'], stages)
    score_str = entity['score']
    if score_str:
        try:
            score_val = -float(score_str)
        except ValueError:
            score_val = 0
    else:
        score_val = 1
    return (order, score_val)


def sort_key_next(entity):
    """Sort key for --next mode: score descending."""
    score_str = entity['score']
    if score_str:
        try:
            return -float(score_str)
        except ValueError:
            return 0
    return 1


def print_status_table(entities, stages):
    """Print the default status table."""
    fmt = '%-6s %-30s %-20s %-30s %-8s %s'
    print(fmt % ('ID', 'SLUG', 'STATUS', 'TITLE', 'SCORE', 'SOURCE'))
    print(fmt % ('--', '----', '------', '-----', '-----', '------'))
    sorted_entities = sorted(entities, key=lambda e: sort_key_default(e, stages))
    for e in sorted_entities:
        print(fmt % (e['id'], e['slug'], e['status'], e['title'], e['score'], e['source']))


def print_next_table(entities, stages):
    """Print the --next dispatchable entities table."""
    stage_by_name = {s['name']: s for s in stages}
    stage_names = [s['name'] for s in stages]
    active_counts = {}
    for e in entities:
        if e['worktree']:
            st = e['status']
            active_counts[st] = active_counts.get(st, 0) + 1

    candidates = sorted(entities, key=sort_key_next)
    next_stage_counts = dict(active_counts)
    dispatchable = []
    for e in candidates:
        status = e['status']
        if status not in stage_by_name:
            continue
        stage_idx = stage_names.index(status)
        stage = stage_by_name[status]
        if stage.get('terminal', False):
            continue
        if stage.get('gate', False):
            continue
        if e['worktree']:
            continue
        if stage_idx + 1 >= len(stage_names):
            continue
        next_stage_name = stage_names[stage_idx + 1]
        next_stage = stage_by_name[next_stage_name]
        current_count = next_stage_counts.get(next_stage_name, 0)
        if current_count >= next_stage['concurrency']:
            continue
        next_stage_counts[next_stage_name] = current_count + 1
        dispatchable.append({
            **e,
            'next': next_stage_name,
            'next_worktree': 'yes' if next_stage['worktree'] else 'no',
        })

    fmt = '%-6s %-30s %-20s %-20s %s'
    print(fmt % ('ID', 'SLUG', 'CURRENT', 'NEXT', 'WORKTREE'))
    print(fmt % ('--', '----', '-------', '----', '--------'))
    for e in dispatchable:
        print(fmt % (e['id'], e['slug'], e['status'], e['next'], e['next_worktree']))


def scan_mods(workflow_dir):
    """Scan _mods/*.md for ## Hook: headings, return {hook_point: [mod_names]} mapping."""
    mods_dir = os.path.join(workflow_dir, '_mods')
    if not os.path.isdir(mods_dir):
        return {}
    hooks = {}
    for filepath in sorted(glob.glob(os.path.join(mods_dir, '*.md'))):
        mod_name = os.path.splitext(os.path.basename(filepath))[0]
        with open(filepath, 'r') as f:
            for line in f:
                line = line.rstrip('\n')
                if line.startswith('## Hook:'):
                    point = line[len('## Hook:'):].strip()
                    if point:
                        hooks.setdefault(point, []).append(mod_name)
    return hooks


def compute_next_id(active_entities, archive_dir):
    """Find the highest numeric ID across active + archived entities, return next ID string."""
    max_id = 0
    all_entities = list(active_entities)
    if os.path.isdir(archive_dir):
        all_entities.extend(scan_entities(archive_dir))
    for e in all_entities:
        id_str = e.get('id', '')
        if id_str:
            try:
                id_num = int(id_str)
                if id_num > max_id:
                    max_id = id_num
            except ValueError:
                pass
    return '%03d' % (max_id + 1)


def scan_orphans(entities, git_root):
    """Return entities with non-empty worktree field, with dir/branch existence info."""
    worktree_paths = {}
    try:
        result = subprocess.run(
            ['git', 'worktree', 'list', '--porcelain'],
            capture_output=True, text=True, cwd=git_root
        )
        if result.returncode == 0:
            current_path = None
            for line in result.stdout.split('\n'):
                if line.startswith('worktree '):
                    current_path = line[len('worktree '):].strip()
                elif line.startswith('branch ') and current_path is not None:
                    worktree_paths[os.path.realpath(current_path)] = True
                elif line == '':
                    current_path = None
    except FileNotFoundError:
        pass

    orphans = []
    for e in entities:
        wt = e.get('worktree', '')
        if not wt:
            continue
        dir_path = os.path.join(git_root, wt)
        dir_exists = 'yes' if os.path.isdir(dir_path) else 'no'
        branch_exists = 'yes' if os.path.realpath(dir_path) in worktree_paths else 'no'
        orphans.append({
            'id': e.get('id', ''),
            'slug': e.get('slug', ''),
            'worktree': wt,
            'dir_exists': dir_exists,
            'branch_exists': branch_exists,
        })
    return orphans


def check_pr_states(entities, stages):
    """Check PR state for entities with non-empty pr and non-terminal status."""
    stage_by_name = {s['name']: s for s in stages}
    pr_entities = []
    for e in entities:
        pr = e.get('pr', '')
        if not pr:
            continue
        status = e.get('status', '')
        stage = stage_by_name.get(status)
        if stage and stage.get('terminal', False):
            continue
        pr_entities.append(e)

    if not pr_entities:
        return 'none', []

    # Check if gh is available
    gh_path = None
    for d in os.environ.get('PATH', '').split(os.pathsep):
        candidate = os.path.join(d, 'gh')
        if os.path.isfile(candidate) and os.access(candidate, os.X_OK):
            gh_path = candidate
            break
    if gh_path is None:
        return 'gh not available', []

    results = []
    for e in pr_entities:
        pr = e.get('pr', '').lstrip('#')
        try:
            result = subprocess.run(
                ['gh', 'pr', 'view', pr, '--json', 'state', '--jq', '.state'],
                capture_output=True, text=True
            )
            if result.returncode == 0:
                state = result.stdout.strip().upper()
            else:
                state = 'ERROR'
        except FileNotFoundError:
            state = 'ERROR'
        results.append({
            'id': e.get('id', ''),
            'slug': e.get('slug', ''),
            'pr': e.get('pr', ''),
            'state': state,
        })
    return 'ok', results


def print_boot(entities, stages, workflow_dir, git_root):
    """Print all boot sections: MODS, NEXT_ID, ORPHANS, PR_STATE, DISPATCHABLE."""
    # MODS
    hooks = scan_mods(workflow_dir)
    if not hooks:
        print('MODS: none')
    else:
        print('MODS')
        for point in sorted(hooks.keys()):
            mods = ', '.join(sorted(hooks[point]))
            print('%s: %s' % (point, mods))

    # NEXT_ID
    archive_dir = os.path.join(workflow_dir, '_archive')
    next_id = compute_next_id(entities, archive_dir)
    print('NEXT_ID: %s' % next_id)

    # ORPHANS
    orphans = scan_orphans(entities, git_root)
    if not orphans:
        print('ORPHANS: none')
    else:
        print('ORPHANS')
        fmt = '%-6s %-30s %-43s %-11s %s'
        print(fmt % ('ID', 'SLUG', 'WORKTREE', 'DIR_EXISTS', 'BRANCH_EXISTS'))
        for o in orphans:
            print(fmt % (o['id'], o['slug'], o['worktree'], o['dir_exists'], o['branch_exists']))

    # PR_STATE
    pr_status, pr_results = check_pr_states(entities, stages)
    if pr_status == 'none':
        print('PR_STATE: none')
    elif pr_status == 'gh not available':
        print('PR_STATE: gh not available')
    else:
        print('PR_STATE')
        fmt = '%-6s %-30s %-8s %s'
        print(fmt % ('ID', 'SLUG', 'PR', 'STATE'))
        for r in pr_results:
            print(fmt % (r['id'], r['slug'], r['pr'], r['state']))

    # DISPATCHABLE
    print('DISPATCHABLE')
    print_next_table(entities, stages)


def parse_where_filters(args):
    """Parse --where arguments from sys.argv."""
    filters = []
    i = 0
    while i < len(args):
        if args[i] == '--where':
            if i + 1 >= len(args):
                raise ValueError('--where requires an argument')
            where_arg = args[i + 1]
            parts = where_arg.split(None, 1)
            if not parts:
                raise ValueError('--where argument cannot be empty')
            field = parts[0]
            op = None
            value = None
            if len(parts) == 1:
                op = '!='
            else:
                remainder = parts[1]
                op_parts = remainder.split(None, 1)
                op = op_parts[0]
                value = op_parts[1] if len(op_parts) > 1 else None
            filters.append((field, op, value))
            i += 2
        else:
            i += 1
    return filters


def parse_workflow_dir(args):
    """Extract --workflow-dir from argv and return (workflow_dir, remaining_args)."""
    remaining = []
    workflow_dir = None
    i = 0
    while i < len(args):
        if args[i] == '--workflow-dir':
            if i + 1 >= len(args):
                raise ValueError('--workflow-dir requires an argument')
            workflow_dir = args[i + 1]
            i += 2
            continue
        remaining.append(args[i])
        i += 1
    return workflow_dir, remaining


TIMESTAMP_FIELDS = {'started', 'completed'}


def parse_set_args(args):
    """Parse --set arguments, returning (slug, field_updates) or None.

    field_updates is a list of (field, value) tuples where value is:
    - a string for explicit field=value
    - '' for field= (clear)
    - None for bare timestamp fields (auto-fill with now())
    """
    i = 0
    while i < len(args):
        if args[i] == '--set':
            if i + 1 >= len(args):
                raise ValueError('--set requires a slug argument')
            slug = args[i + 1]
            updates = []
            j = i + 2
            while j < len(args) and not args[j].startswith('--'):
                arg = args[j]
                if '=' in arg:
                    field, _, value = arg.partition('=')
                    updates.append((field, value))
                elif arg in TIMESTAMP_FIELDS:
                    updates.append((arg, None))
                else:
                    raise ValueError(
                        f"bare field '{arg}' requires a value (use {arg}=value); "
                        f"only {', '.join(sorted(TIMESTAMP_FIELDS))} support auto-fill"
                    )
                j += 1
            if not updates:
                raise ValueError('--set requires at least one field=value argument')
            return slug, updates
        i += 1
    return None


def update_frontmatter(filepath, updates):
    """Rewrite frontmatter fields in a file. Returns dict of updated fields."""
    with open(filepath, 'r') as f:
        content = f.read()

    lines = content.split('\n')
    in_fm = False
    fm_start = None
    fm_end = None
    for i, line in enumerate(lines):
        if line.rstrip() == '---':
            if not in_fm:
                in_fm = True
                fm_start = i
            else:
                fm_end = i
                break

    if fm_start is None or fm_end is None:
        raise ValueError(f'No frontmatter found in {filepath}')

    # Read current values to support skip-if-set for timestamp fields
    current_values = {}
    for i in range(fm_start + 1, fm_end):
        line = lines[i]
        if ':' in line and not line[0].isspace():
            key, _, val = line.partition(':')
            current_values[key.strip()] = val.strip()

    # Resolve auto-fill timestamps
    resolved = {}
    now_str = datetime.now(timezone.utc).strftime('%Y-%m-%dT%H:%M:%SZ')
    for field, value in updates:
        if value is None:
            # Bare timestamp field — skip if already has a value
            if current_values.get(field, ''):
                continue
            resolved[field] = now_str
        else:
            resolved[field] = value

    # Rewrite matching lines in frontmatter
    for i in range(fm_start + 1, fm_end):
        line = lines[i]
        if ':' in line and not line[0].isspace():
            key, _, _ = line.partition(':')
            key_stripped = key.strip()
            if key_stripped in resolved:
                lines[i] = f'{key_stripped}: {resolved[key_stripped]}'

    with open(filepath, 'w') as f:
        f.write('\n'.join(lines))

    return resolved


def apply_filters(entities, filters):
    """Filter entities based on --where conditions."""
    if not filters:
        return entities
    filtered = []
    for e in entities:
        match = True
        for field, op, value in filters:
            field_val = e.get(field, '')
            if op == '!=':
                if value is None:
                    if not field_val:
                        match = False
                        break
                else:
                    if field_val == value:
                        match = False
                        break
            elif op == '=':
                if value is None:
                    if field_val:
                        match = False
                        break
                else:
                    if field_val != value:
                        match = False
                        break
        if match:
            filtered.append(e)
    return filtered


def find_git_root(start_dir):
    """Walk up from start_dir to find the .git directory, return its parent."""
    d = os.path.abspath(start_dir)
    while True:
        if os.path.isdir(os.path.join(d, '.git')) or os.path.isfile(os.path.join(d, '.git')):
            return d
        parent = os.path.dirname(d)
        if parent == d:
            return start_dir
        d = parent


def main():
    args = sys.argv[1:]
    try:
        workflow_dir, args = parse_workflow_dir(args)
    except ValueError as e:
        print('Error: ' + str(e), file=sys.stderr)
        sys.exit(1)

    pipeline_dir = workflow_dir or os.environ.get('PIPELINE_DIR') or os.path.dirname(os.path.abspath(__file__))

    # Parse --set before other flags
    try:
        set_result = parse_set_args(args)
    except ValueError as e:
        print('Error: ' + str(e), file=sys.stderr)
        sys.exit(1)

    include_archive = '--archived' in args
    show_next = '--next' in args
    show_boot = '--boot' in args

    # --boot is incompatible with --next, --archived, --where
    if show_boot:
        if show_next:
            print('Error: --boot is incompatible with --next', file=sys.stderr)
            sys.exit(1)
        if include_archive:
            print('Error: --boot is incompatible with --archived', file=sys.stderr)
            sys.exit(1)

    try:
        where_filters = parse_where_filters(args)
    except ValueError as e:
        print('Error: ' + str(e), file=sys.stderr)
        sys.exit(1)

    if show_boot and where_filters:
        print('Error: --boot is incompatible with --where', file=sys.stderr)
        sys.exit(1)

    if set_result is not None:
        # Check for incompatible flags
        incompatible = []
        if show_next:
            incompatible.append('--next')
        if include_archive:
            incompatible.append('--archived')
        if show_boot:
            incompatible.append('--boot')
        if where_filters:
            incompatible.append('--where')
        if incompatible:
            print(f'Error: --set cannot be combined with {", ".join(incompatible)}',
                  file=sys.stderr)
            sys.exit(1)

        slug, updates = set_result
        entity_path = os.path.join(pipeline_dir, slug + '.md')
        if not os.path.exists(entity_path):
            print(f'Error: entity not found: {slug}.md', file=sys.stderr)
            sys.exit(1)

        try:
            resolved = update_frontmatter(entity_path, updates)
        except ValueError as e:
            print('Error: ' + str(e), file=sys.stderr)
            sys.exit(1)

        for field, value in resolved.items():
            print(f'{field}: {value}')
        sys.exit(0)

    readme_path = os.path.join(pipeline_dir, 'README.md')
    stages = None
    if os.path.exists(readme_path):
        stages = parse_stages_block(readme_path)

    if show_next and stages is None:
        print('Error: README.md has no stages block. --next requires stage metadata.', file=sys.stderr)
        sys.exit(1)

    if show_boot and stages is None:
        print('Error: README.md has no stages block. --boot requires stage metadata.', file=sys.stderr)
        sys.exit(1)

    entities = scan_entities(pipeline_dir)
    if include_archive:
        archive_dir = os.path.join(pipeline_dir, '_archive')
        if os.path.isdir(archive_dir):
            entities.extend(scan_entities(archive_dir))

    entities = apply_filters(entities, where_filters)

    if show_boot:
        git_root = find_git_root(pipeline_dir)
        print_boot(entities, stages, pipeline_dir, git_root)
    elif show_next:
        print_next_table(entities, stages)
    else:
        print_status_table(entities, stages)


if __name__ == '__main__':
    main()
