#!/bin/bash
# commissioned-by: spacedock@0.1.4
# The actual program generated below is a version of the description:
#
# goal: Show one-line-per-entity pipeline overview from YAML frontmatter.
# instruction: For every .md file in this directory (excluding README.md),
#   extract slug (filename without .md), status, verdict, score, source from YAML frontmatter.
#   Print table with columns: SLUG, STATUS, TITLE, SCORE, SOURCE.
#   Sorted by stage order then score descending.
# constraints: bash 3.2+ (no associative arrays), resolves paths relative to this script, skips README.md.
# valid status values: backlog, ideation, implementation, validation, done.

DIR="$(cd "$(dirname "$0")" && pwd)"

stage_order() {
  case "$1" in
    backlog) echo 1 ;;
    ideation) echo 2 ;;
    implementation) echo 3 ;;
    validation) echo 4 ;;
    done) echo 5 ;;
    *) echo 99 ;;
  esac
}

printf "%-30s %-20s %-30s %-8s %s\n" "SLUG" "STATUS" "TITLE" "SCORE" "SOURCE"
printf "%-30s %-20s %-30s %-8s %s\n" "----" "------" "-----" "-----" "------"

for f in "$DIR"/*.md; do
  [ "$(basename "$f")" = "README.md" ] && continue
  slug=$(basename "$f" .md)
  status="" title="" score="" source=""
  in_fm=false
  while IFS= read -r line; do
    if [ "$line" = "---" ]; then
      if $in_fm; then break; fi
      in_fm=true; continue
    fi
    if $in_fm; then
      case "$line" in
        status:*) status="${line#*:}" ; status="${status# }" ;;
        title:*) title="${line#*:}" ; title="${title# }" ;;
        score:*) score="${line#*:}" ; score="${score# }" ;;
        source:*) source="${line#*:}" ; source="${source# }" ;;
      esac
    fi
  done < "$f"
  order=$(stage_order "$status")
  printf "%s\t%s\t%s\t%s\t%s\t%s\t%s\n" "$order" "$score" "$slug" "$status" "$title" "$score" "$source"
done | sort -t$'\t' -k1,1n -k2,2rn | awk -F'\t' '{ printf "%-30s %-20s %-30s %-8s %s\n", $3, $4, $5, $6, $7 }'
